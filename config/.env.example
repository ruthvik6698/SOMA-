# SOMA — Environment Configuration
# Copy to config/.env and fill in your values

# Tapo L530 Smart Bulb (TP-Link)
TAPO_IP=192.168.0.xxx
TAPO_EMAIL=your@email.com
TAPO_PASSWORD=your_password

# WHOOP API (developer.whoop.com)
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret
WHOOP_ACCESS_TOKEN=
WHOOP_REFRESH_TOKEN=

# OpenAI (for natural language commands)
OPENAI_API_KEY=sk-your-openai-api-key

# Weather (weatherapi.com — free tier)
WEATHER_API_KEY=your_weatherapi_key
WEATHER_LOCATION=Hyderabad
